flowchart TD
    START["Checkout Request<br/>Consumer selects BNPL<br/>Order: $200, Merchant: Nike"]

    START --> IDENTITY["Identity Verification<br/>Email, phone, name, DOB<br/>Device fingerprint, IP geolocation"]

    IDENTITY --> FRAUD{"Fraud Scoring<br/>ML model"}
    FRAUD -->|"Score > 0.85<br/>High fraud risk"| DECLINE_FRAUD["DECLINE<br/>Suspected fraud<br/>Reason: risk signals"]
    FRAUD -->|"Score < 0.85<br/>Acceptable"| CREDIT_CHECK

    CREDIT_CHECK["Credit Check<br/>Soft pull (no hard inquiry)<br/>TransUnion, Experian, or Equifax"]

    CREDIT_CHECK --> INTERNAL{"Internal History<br/>Check"}
    INTERNAL -->|"Previous defaults<br/>or chargebacks"| DECLINE_HISTORY["DECLINE<br/>Poor repayment history"]
    INTERNAL -->|"Good history<br/>or new customer"| AFFORD

    AFFORD{"Affordability<br/>Assessment"}
    AFFORD -->|"Existing BNPL balance<br/>too high"| DECLINE_AFFORD["DECLINE<br/>Over-committed<br/>Existing obligations too high"]
    AFFORD -->|"Within limits"| RISK_TIER

    RISK_TIER{"Risk Tier<br/>Assignment"}
    RISK_TIER -->|"Tier 1: Excellent<br/>Score 750+, repeat customer"| APPROVE_T1["APPROVE<br/>Pay in 4 (0% APR)<br/>Up to $1,500 limit"]
    RISK_TIER -->|"Tier 2: Good<br/>Score 650-749"| APPROVE_T2["APPROVE<br/>Pay in 4 (0% APR)<br/>Up to $500 limit"]
    RISK_TIER -->|"Tier 3: Fair<br/>Score 550-649"| APPROVE_T3["APPROVE<br/>Pay in 4 (0% APR)<br/>Up to $250 limit<br/>OR installment loan with APR"]
    RISK_TIER -->|"Tier 4: Poor<br/>Score < 550"| DECLINE_CREDIT["DECLINE<br/>Credit risk too high"]

    APPROVE_T1 --> ORIGINATE["Loan Origination<br/>Via bank partner (WebBank)<br/>for regulatory compliance"]
    APPROVE_T2 --> ORIGINATE
    APPROVE_T3 --> ORIGINATE

    ORIGINATE --> PRESENT["Present Payment Plan<br/>to Consumer<br/>4x $50 biweekly"]

    Note1["Total decision time:<br/>0.5 to 2 seconds"]
    Note2["Approval rates:<br/>Klarna: ~70-75%<br/>Affirm: ~65-70%<br/>Afterpay: ~75-80%"]

