    style ISP_AU fill:#f3e5f5,stroke:#6a1b9a,stroke-width:2px
    style POP_NYC fill:#e3f2fd,stroke:#1565c0,stroke-width:2px
    style POP_LON fill:#e3f2fd,stroke:#1565c0,stroke-width:2px
