graph TD
    subgraph USERS["End Users"]
        U1["User A<br/>Tokyo"]
        U2["User B<br/>Osaka"]
        U3["User C<br/>Paris"]
        U4["User D<br/>Frankfurt"]
        U5["User E<br/>New York"]
    end

    subgraph L1["Tier 1: Edge Cache (L1)<br/>Lowest latency, smallest cache, per-PoP"]
        E_TOK["Edge Tokyo<br/>5ms RTT<br/>Cache: 2TB SSD"]
        E_OSA["Edge Osaka<br/>3ms RTT<br/>Cache: 2TB SSD"]
        E_PAR["Edge Paris<br/>4ms RTT<br/>Cache: 2TB SSD"]
        E_FRA["Edge Frankfurt<br/>3ms RTT<br/>Cache: 2TB SSD"]
        E_NYC["Edge New York<br/>5ms RTT<br/>Cache: 2TB SSD"]
    end

    subgraph L2["Tier 2: Mid-Tier / Regional Cache (L2)<br/>Aggregates edge misses, larger cache"]
        R_ASIA["Regional Asia<br/>Singapore hub<br/>Cache: 20TB"]
        R_EU["Regional Europe<br/>Frankfurt hub<br/>Cache: 20TB"]
        R_US["Regional US East<br/>Ashburn hub<br/>Cache: 20TB"]
    end

    subgraph L3["Tier 3: Origin Shield<br/>Single point of contact for origin"]
        SHIELD["Origin Shield<br/>Ashburn, Virginia<br/>Collapses all requests"]
    end

    subgraph ORIGIN_DC["Origin Data Center"]
        ORIGIN["Origin Server<br/>Customer's infrastructure"]
    end

    U1 --> E_TOK
    U2 --> E_OSA
    U3 --> E_PAR
    U4 --> E_FRA
    U5 --> E_NYC

    E_TOK -->|"L1 MISS"| R_ASIA
    E_OSA -->|"L1 MISS"| R_ASIA
    E_PAR -->|"L1 MISS"| R_EU
    E_FRA -->|"L1 MISS"| R_EU
    E_NYC -->|"L1 MISS"| R_US

    R_ASIA -->|"L2 MISS"| SHIELD
    R_EU -->|"L2 MISS"| SHIELD
    R_US -->|"L2 MISS"| SHIELD

    SHIELD -->|"Shield MISS<br/>(only request origin sees)"| ORIGIN

