        B7["Rewards<br/>Generally none<br/>(Klarna Vibe: limited cashback)"]
        B8["Who Pays<br/>Merchant pays 3-8% MDR<br/>Consumer pays $0 if on time"]
    end

    subgraph CARD_SIDE["Traditional Credit Card"]
        C1["Credit Check<br/>Hard pull required<br/>Impacts credit score"]
        C2["Interest Rate<br/>0% intro APR (6-21 months)<br/>Then 18-30% APR"]
        C3["Repayment<br/>Minimum payment (revolving)<br/>Easy to carry balance"]
        C4["Credit Limit<br/>Ongoing line of credit<br/>$500 to $50,000+"]
        C5["Late Fees<br/>$25-$41 per missed payment<br/>+ penalty APR up to 29.99%"]
        C6["Credit Reporting<br/>Always reported<br/>Builds credit history"]
        C7["Rewards<br/>1-5% cashback<br/>Points, miles, travel perks"]
        C8["Who Pays<br/>Merchant pays 1.5-3.5% MDR<br/>Consumer pays interest if revolving"]
    end

    subgraph WINNER["Best For"]
        W1["BNPL wins when:<br/>- Young consumer, thin credit file<br/>- Want 0% interest guaranteed<br/>- Specific purchase, fixed repayment<br/>- No credit score impact desired"]
        W2["Credit card wins when:<br/>- Want rewards/cashback<br/>- Building credit history<br/>- Need ongoing credit line<br/>- Want purchase protection/disputes<br/>- Higher spending power needed"]
    end

