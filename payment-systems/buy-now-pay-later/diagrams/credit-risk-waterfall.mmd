        L_INSTALL["Installment Loans (longer-term)<br/>Net loss rate: 3-8%<br/>Higher amounts, longer exposure"]
        L_COMPARE["For comparison:<br/>Credit card net loss: 3-4%<br/>Subprime credit card: 8-12%"]
    end

    subgraph PROVIDER_LOSSES["Provider-Specific (FY 2024)"]
