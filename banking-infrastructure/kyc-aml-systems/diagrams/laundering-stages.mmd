flowchart LR
    Crime[Criminal Activity<br/>Drug trafficking,<br/>corruption, fraud,<br/>tax evasion]

    subgraph Stage1 [Stage 1: PLACEMENT]
        Cash[Cash deposits<br/>below 10K threshold]
        Smurfing[Smurfing<br/>Multiple small deposits<br/>across branches]
        CashBiz[Cash-intensive business<br/>Car wash, restaurant,<br/>casino]
        Purchase[Purchase monetary<br/>instruments<br/>Money orders, cashier checks]
    end

    subgraph Stage2 [Stage 2: LAYERING]
        Wire[Wire transfers<br/>Domestic and international]
        Shell[Shell company<br/>transactions]
        Trade[Trade-based laundering<br/>Over/under-invoicing]
        RealEstate[Real estate<br/>purchases and sales]
        Crypto[Cryptocurrency<br/>conversion and mixing]
        Offshore[Offshore accounts<br/>Multiple jurisdictions]
    end

    subgraph Stage3 [Stage 3: INTEGRATION]
        LegitBiz[Legitimate business<br/>investment]
        Luxury[Luxury purchases<br/>Art, jewelry, yachts]
        Loans[Back-to-back loans<br/>using laundered collateral]
        Investment[Securities and<br/>fund investments]
        CleanMoney[Money appears<br/>LEGITIMATE]
    end

    Crime -->|Dirty cash| Stage1
    Stage1 -->|Funds in system| Stage2
    Stage2 -->|Distance created| Stage3

    subgraph Detection [Where AML Detects]
        CTR_Det[CTRs catch<br/>large cash]
        TM_Det[Transaction monitoring<br/>catches patterns]
        Screen_Det[Screening catches<br/>known bad actors]
        SAR_Det[SARs filed on<br/>suspicious activity]
    end

    Stage1 -.Detected by.-> CTR_Det
    Stage2 -.Detected by.-> TM_Det
    Stage1 -.Detected by.-> Screen_Det
    Stage2 -.Detected by.-> SAR_Det
    Stage3 -.Hardest to detect.-> SAR_Det

