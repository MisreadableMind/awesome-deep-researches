    DPD1 --> CURED1["Cured<br/>~60% of DPD1 pay within 30 days"]
    DPD1 --> DPD30["31-60 Days Past Due<br/>~1.5-2% of originations<br/>Account paused, phone calls"]

    DPD30 --> CURED2["Cured<br/>~40% of DPD30 pay"]
    DPD30 --> DPD60["61-90 Days Past Due<br/>~0.8-1.2% of originations<br/>Formal demand letter"]

    DPD60 --> CURED3["Cured<br/>~20% of DPD60 pay"]
    DPD60 --> DPD90["91-120 Days Past Due<br/>~0.5-0.8% of originations<br/>Pre-charge-off"]

    DPD90 --> CHARGEOFF["Charge-Off<br/>~120-180 days past due<br/>0.3-0.6% of originations<br/>Written off as loss"]

    CHARGEOFF --> INTERNAL_COLLECT["Internal Collections<br/>Attempt to recover<br/>Recovery rate: 10-15%"]
    CHARGEOFF --> SOLD["Sold to Debt Buyer<br/>At 5-15 cents on the dollar<br/>e.g. Encore Capital, PRA Group"]

    subgraph LOSS_RATES["Industry Loss Rates (2024-2025)"]
