%%{init: {'theme': 'base', 'themeVariables': {'primaryColor': '#e3f2fd', 'primaryBorderColor': '#1565c0', 'lineColor': '#37474f'}}}%%

graph TD
    subgraph USER_SIDE["End User Side"]
        USER["End User<br/>Browser or App"]
        DNS_RES["DNS Resolver<br/>1.1.1.1, 8.8.8.8, ISP"]
    end

    subgraph CDN_LAYER["CDN Provider Layer"]
        CDN_DNS["CDN Authoritative DNS<br/>Anycast or GeoDNS"]
        EDGE["Edge Server / PoP<br/>Cache, WAF, DDoS, TLS"]
        MID["Mid-Tier / Origin Shield<br/>Regional cache aggregation"]
    end

    subgraph NETWORK_LAYER["Network Infrastructure"]
        IXP["Internet Exchange Point<br/>DE-CIX, LINX, AMS-IX"]
        ISP["ISP / Transit Provider<br/>Comcast, NTT, DT"]
    end

    subgraph ORIGIN_SIDE["Content Publisher Side"]
        ORIGIN["Origin Server<br/>Customer infrastructure"]
        CA["Certificate Authority<br/>Let's Encrypt, DigiCert"]
    end

    subgraph CDN_PROVIDERS["Major CDN Providers"]
        CF["Cloudflare<br/>330+ cities, Anycast"]
        AK["Akamai<br/>4,200+ locations, DNS-based"]
        CFNT["AWS CloudFront<br/>600+ PoPs"]
        FAST["Fastly<br/>90+ PoPs, instant purge"]
    end

    USER -->|"DNS query"| DNS_RES
    DNS_RES -->|"resolve domain"| CDN_DNS
    CDN_DNS -->|"return edge IP"| DNS_RES
    DNS_RES -->|"edge IP"| USER

    USER -->|"HTTP request"| ISP
    ISP -->|"route via BGP"| IXP
    IXP -->|"direct peering"| EDGE

    EDGE -->|"cache MISS"| MID
    MID -->|"cache MISS"| ORIGIN

    CA -.->|"TLS certificates"| EDGE
    CA -.->|"TLS certificates"| ORIGIN

    CF -.->|"operates"| EDGE
    AK -.->|"operates"| EDGE
    CFNT -.->|"operates"| EDGE
    FAST -.->|"operates"| EDGE

    style USER fill:#e8f5e9,stroke:#2e7d32,stroke-width:2px
    style EDGE fill:#e3f2fd,stroke:#1565c0,stroke-width:2px
    style MID fill:#e3f2fd,stroke:#1565c0,stroke-width:2px
    style CDN_DNS fill:#e3f2fd,stroke:#1565c0,stroke-width:2px
    style ORIGIN fill:#fff3e0,stroke:#e65100,stroke-width:2px
    style IXP fill:#f3e5f5,stroke:#6a1b9a,stroke-width:2px
    style ISP fill:#f3e5f5,stroke:#6a1b9a,stroke-width:2px
    style CF fill:#fff8e1,stroke:#f57f17,stroke-width:2px
    style AK fill:#fff8e1,stroke:#f57f17,stroke-width:2px
    style CFNT fill:#fff8e1,stroke:#f57f17,stroke-width:2px
    style FAST fill:#fff8e1,stroke:#f57f17,stroke-width:2px
    style USER_SIDE fill:#fafafa,stroke:#9e9e9e
    style CDN_LAYER fill:#fafafa,stroke:#9e9e9e
    style NETWORK_LAYER fill:#fafafa,stroke:#9e9e9e
    style ORIGIN_SIDE fill:#fafafa,stroke:#9e9e9e
    style CDN_PROVIDERS fill:#fafafa,stroke:#9e9e9e
