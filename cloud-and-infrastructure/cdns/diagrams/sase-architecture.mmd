%%{init: {'theme': 'base', 'themeVariables': {'primaryColor': '#e3f2fd', 'primaryBorderColor': '#1565c0', 'lineColor': '#37474f'}}}%%

graph TD
    subgraph TRADITIONAL["Traditional Model (VPN + Appliances)"]
        T_USER["Remote User"]
        T_VPN["VPN Concentrator<br/>Single point of entry"]
        T_FW["Corporate Firewall<br/>On-premises"]
        T_WAF_T["WAF Appliance<br/>On-premises"]
        T_APP["Corporate Apps"]
        T_SAAS["SaaS Apps<br/>(hairpin through DC)"]

        T_USER -->|"VPN tunnel"| T_VPN
        T_VPN --> T_FW
        T_FW --> T_WAF_T
        T_WAF_T --> T_APP
        T_WAF_T -->|"backhauled"| T_SAAS
    end

    subgraph SASE_MODEL["SASE Model (CDN Edge = Security + Network)"]
        S_USER["Remote User<br/>Any device, any location"]
        S_AGENT["WARP Agent / Client<br/>Lightweight tunnel"]

        subgraph CDN_EDGE["CDN Edge PoP (Nearest)"]
            S_ID["Identity Check<br/>SSO / IdP integration<br/>Device posture"]
            S_SWG["Secure Web Gateway<br/>URL filtering,<br/>malware scanning"]
            S_WAF["WAF + DDoS<br/>Application protection"]
            S_DLP["Data Loss Prevention<br/>Sensitive data detection"]
            S_CASB["CASB<br/>SaaS security<br/>and visibility"]
            S_ZTNA["Zero Trust Network Access<br/>Per-request authorization"]
        end

        S_APP["Corporate Apps<br/>(via Tunnel)"]
        S_SAAS["SaaS Apps<br/>(direct from edge)"]
        S_INTERNET["Public Internet<br/>(filtered)"]

        S_USER --> S_AGENT
        S_AGENT --> S_ID
        S_ID --> S_SWG
        S_ID --> S_ZTNA
        S_SWG --> S_WAF
        S_WAF --> S_DLP
        S_DLP --> S_CASB

        S_ZTNA -->|"authorized"| S_APP
        S_CASB -->|"monitored"| S_SAAS
        S_SWG -->|"filtered"| S_INTERNET
    end

    style T_USER fill:#ffcdd2,stroke:#c62828
    style T_VPN fill:#ffcdd2,stroke:#c62828
    style T_FW fill:#ffcdd2,stroke:#c62828
    style T_WAF_T fill:#ffcdd2,stroke:#c62828
    style T_APP fill:#ffcdd2,stroke:#c62828
    style T_SAAS fill:#ffcdd2,stroke:#c62828

    style S_USER fill:#e8f5e9,stroke:#2e7d32,stroke-width:2px
    style S_AGENT fill:#e8f5e9,stroke:#2e7d32
    style S_ID fill:#e3f2fd,stroke:#1565c0,stroke-width:2px
    style S_SWG fill:#e3f2fd,stroke:#1565c0
    style S_WAF fill:#e3f2fd,stroke:#1565c0
    style S_DLP fill:#e3f2fd,stroke:#1565c0
    style S_CASB fill:#e3f2fd,stroke:#1565c0
    style S_ZTNA fill:#e3f2fd,stroke:#1565c0
    style S_APP fill:#c8e6c9,stroke:#2e7d32
    style S_SAAS fill:#c8e6c9,stroke:#2e7d32
    style S_INTERNET fill:#c8e6c9,stroke:#2e7d32

    style TRADITIONAL fill:#fff3e0,stroke:#e65100
    style SASE_MODEL fill:#fafafa,stroke:#9e9e9e
    style CDN_EDGE fill:#e8eaf6,stroke:#283593
