%%{init: {'theme': 'base', 'themeVariables': {'primaryColor': '#e3f2fd', 'primaryBorderColor': '#1565c0', 'lineColor': '#37474f'}}}%%

graph LR
    subgraph REQUEST["Incoming Request"]
        REQ["HTTP Request<br/>from User"]
    end

    subgraph CF_WORKERS["Cloudflare Workers"]
        CF_ISO["V8 Isolate<br/>Cold start: less than 1ms<br/>CPU: 10ms free, 30s paid<br/>Memory: 128 MB<br/>Languages: JS, TS, Rust/Wasm"]
        CF_STORE["Storage:<br/>KV, R2, D1,<br/>Durable Objects,<br/>Queues, Vectorize"]
        CF_LOC["330+ cities"]
    end

    subgraph AKAMAI_EW["Akamai EdgeWorkers"]
        AK_ISO["V8 Runtime<br/>Cold start: ~5ms<br/>CPU: 4ms init + 4ms/event<br/>Memory: 512 KB<br/>Languages: JavaScript"]
        AK_STORE["Storage:<br/>EdgeKV"]
        AK_LOC["4,200+ locations"]
    end

    subgraph AWS_LAMBDA["AWS Lambda@Edge"]
        AWS_CON["Node.js Container<br/>Cold start: 50-500ms<br/>CPU: 5s viewer, 30s origin<br/>Memory: 128 MB<br/>Languages: Node.js, Python"]
        AWS_STORE["Storage:<br/>DynamoDB, S3<br/>(origin region only)"]
        AWS_LOC["400+ PoPs"]
    end

    subgraph FASTLY_C["Fastly Compute"]
        FAST_WASM["Wasmtime Runtime<br/>Cold start: less than 1ms<br/>CPU: 60s total<br/>Memory: 128 MB<br/>Languages: Rust, Go, JS/Wasm"]
        FAST_STORE["Storage:<br/>KV Store,<br/>Object Store"]
        FAST_LOC["90+ PoPs"]
    end

    REQ --> CF_ISO
    REQ --> AK_ISO
    REQ --> AWS_CON
    REQ --> FAST_WASM

    CF_ISO --> CF_STORE
    CF_ISO --> CF_LOC
    AK_ISO --> AK_STORE
    AK_ISO --> AK_LOC
    AWS_CON --> AWS_STORE
    AWS_CON --> AWS_LOC
    FAST_WASM --> FAST_STORE
    FAST_WASM --> FAST_LOC

