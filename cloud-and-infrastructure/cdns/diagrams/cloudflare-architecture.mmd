%%{init: {'theme': 'base', 'themeVariables': {'primaryColor': '#e3f2fd', 'primaryBorderColor': '#1565c0', 'lineColor': '#37474f'}}}%%

graph TD
    subgraph INTERNET["Internet"]
        USER["End User"]
        ATTACKER["DDoS Attacker"]
    end

    subgraph ANYCAST_LAYER["Anycast Layer - Same IP, Every PoP"]
        BGP["BGP Anycast<br/>104.16.0.0/12<br/>Announced from 330+ cities"]
    end

    subgraph SINGLE_SERVER["Every Cloudflare Server (Identical Stack)"]
        subgraph L4["Layer 4 Processing"]
            XDP["XDP / eBPF<br/>Line-rate packet filtering<br/>DDoS: volumetric mitigation"]
            UNIMOG["Unimog<br/>L4 Load Balancer<br/>Cross-PoP forwarding"]
        end

        subgraph L7["Layer 7 Processing"]
            PINGORA["Pingora (Rust)<br/>HTTP Proxy<br/>Replaced NGINX"]
            WAF_ENGINE["WAF Engine<br/>OWASP CRS + Custom Rules<br/>Wirefilter DSL"]
            BOT["Bot Management<br/>JA3/JA4, JS challenges<br/>Turnstile"]
            CACHE["Cache Layer<br/>SSD + RAM<br/>Custom eviction"]
        end

        subgraph COMPUTE["Edge Compute"]
            WORKERS["Workers Runtime<br/>V8 Isolates<br/>Sub-ms cold start"]
            KV["Workers KV<br/>Global key-value"]
            R2_EDGE["R2 Storage<br/>S3-compatible<br/>Zero egress"]
            D1["D1 Database<br/>SQLite at edge"]
            DO["Durable Objects<br/>Stateful edge actors"]
        end

        subgraph SERVICES["Platform Services"]
            DNS_AUTH["Authoritative DNS<br/>Fastest globally"]
            DNS_RES["1.1.1.1 Resolver<br/>Privacy-focused"]
            TUNNEL["Cloudflare Tunnel<br/>Secure origin connection"]
            SPECTRUM_SVC["Spectrum<br/>L4 proxy (TCP/UDP)"]
        end
    end

    subgraph CONFIG["Global Configuration"]
        QUICKSILVER["Quicksilver<br/>Distributed KV<br/>Sub-5s global propagation<br/>200M+ changes/day"]
    end

    subgraph BACKBONE["Cloudflare Backbone"]
        ARGO["Argo Smart Routing<br/>Optimized origin path<br/>~30% latency reduction"]
    end

    USER --> BGP
    ATTACKER --> BGP
    BGP --> XDP
    XDP -->|"clean traffic"| UNIMOG
    XDP -->|"drop attack traffic"| XDP
    UNIMOG --> PINGORA
    PINGORA --> WAF_ENGINE
    WAF_ENGINE --> BOT
    BOT --> CACHE
    CACHE -->|"HIT"| PINGORA
    CACHE -->|"MISS"| WORKERS
    WORKERS --> KV
    WORKERS --> R2_EDGE
    WORKERS --> D1
    WORKERS --> DO
    CACHE -->|"MISS (no Worker)"| ARGO
    ARGO -->|"via backbone"| TUNNEL

    QUICKSILVER -.->|"push config"| SINGLE_SERVER

    PINGORA --> DNS_AUTH
    PINGORA --> DNS_RES
    PINGORA --> SPECTRUM_SVC

