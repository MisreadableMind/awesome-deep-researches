flowchart LR
    Submission[New Submission]

    subgraph DocIntel [Document Intelligence]
        OCR[OCR / Layout Analysis]
        LLM[LLM Extraction<br/>Fields from PDFs, emails]
        Validation[Data Validation &<br/>Normalization]
    end

    subgraph Enrich [Enrichment Orchestration]
        APIs[External API Calls<br/>LexisNexis, Cape, RMS,<br/>D&B, HazardHub]
        Feat[Feature Engineering<br/>Derive rating features]
    end

    subgraph Models [Model Layer]
        Triage[Triage Model<br/>GBM / XGBoost<br/>Likely to bind?<br/>Likely profitable?]
        Risk[Risk Scoring<br/>Hazard + frequency +<br/>severity model]
        Pricing[Pricing Model<br/>GLM / ML<br/>filed with regulator]
        Fraud[Fraud Detection<br/>Anomaly detection<br/>Graph analytics]
        CV[Computer Vision<br/>Property condition,<br/>damage assessment]
    end

    subgraph Governance [Model Governance]
        Explain[Explainability<br/>SHAP / LIME]
        Fairness[Fairness Testing<br/>CO SB21-169, NAIC]
        Drift[Drift Monitoring]
        Filing[Regulatory Filing]
    end

    subgraph Decision [Decision]
        AutoAccept[Auto-accept<br/>Standard case]
        AutoDecline[Auto-decline<br/>Outside appetite]
        HumanReview[Human Underwriter<br/>Complex / referral]
    end

    Submission --> DocIntel
    DocIntel --> Enrich
    Enrich --> Models
    Models --> Governance
    Governance --> Decision

    Triage --> AutoAccept
    Triage --> HumanReview
    Triage --> AutoDecline
    Risk --> Pricing
    Pricing --> HumanReview
    Pricing --> AutoAccept
    CV --> Risk
    Fraud --> HumanReview

    HumanReview -.Feedback.-> Models
    AutoAccept -.Outcomes.-> Models

