graph TD
    subgraph PARTICIPANTS["Participants"]
        BANK["Banks and PSPs"]
        NCB["National Central Banks"]
        CSM_P["CSMs and ACHs"]
    end

    subgraph GATEWAY["Single Access Point"]
        ESMIG["ESMIG<br/>Eurosystem Single Market<br/>Infrastructure Gateway<br/>Unified entry point for all services"]
