%%{init: {'theme': 'base', 'themeVariables': {'primaryColor': '#e3f2fd', 'primaryBorderColor': '#1565c0', 'lineColor': '#37474f'}}}%%

graph TD
    subgraph CONSUMER_SIDE["Consumer Side"]
        CONSUMER["Consumer<br/>Shops online or in-store<br/>Wants to split payments"]
    end

    subgraph BNPL_PROVIDERS["BNPL Providers"]
        KLARNA["Klarna<br/>Founded 2005, Sweden<br/>Pay in 4, financing, pay later"]
        AFFIRM["Affirm<br/>Founded 2012, US<br/>Installment loans, 0% APR promos"]
        AFTERPAY["Afterpay / Block<br/>Founded 2014, Australia<br/>Pay in 4, acquired by Block"]
        ZIP["Zip (formerly Quadpay)<br/>Founded 2013, Australia<br/>Pay in 4, line of credit"]
    end

    subgraph MERCHANT_SIDE["Merchant Side"]
        MERCHANT["Merchant<br/>E-commerce or in-store<br/>Integrates BNPL at checkout"]
        PLATFORM["E-commerce Platform<br/>Shopify, WooCommerce,<br/>BigCommerce, Magento"]
    end

    subgraph FUNDING["Funding and Capital"]
        WAREHOUSE["Warehouse Lenders<br/>Provide credit facilities<br/>Goldman Sachs, Credit Suisse"]
        ABS["ABS Investors<br/>Buy securitized loan pools<br/>Pension funds, hedge funds"]
        BANK_PARTNER["Issuing Bank Partner<br/>Cross River Bank, WebBank<br/>Originate loans for compliance"]
    end

    subgraph PAYMENT_RAILS["Payment Rails"]
        CARD_NETWORK["Card Networks<br/>Visa, Mastercard<br/>Virtual card issuance"]
        PROCESSOR["Payment Processor<br/>Stripe, Adyen, Checkout.com<br/>Processes merchant payments"]
    end

    subgraph REGULATORS["Regulatory Bodies"]
        CFPB["CFPB (US)<br/>Consumer protection"]
        FCA["FCA (UK)<br/>Credit regulation"]
        ASIC["ASIC (Australia)<br/>Financial services"]
    end

    CONSUMER -->|"selects BNPL<br/>at checkout"| MERCHANT
    MERCHANT -->|"integrated via API<br/>or plugin"| PLATFORM
    MERCHANT -->|"receives payment<br/>minus MDR"| PROCESSOR

    KLARNA -->|"pays merchant<br/>upfront"| MERCHANT
    AFFIRM -->|"pays merchant<br/>upfront"| MERCHANT
    AFTERPAY -->|"pays merchant<br/>upfront"| MERCHANT

    CONSUMER -->|"repays in<br/>installments"| KLARNA
    CONSUMER -->|"repays in<br/>installments"| AFFIRM

    BANK_PARTNER -->|"originates loans<br/>for compliance"| AFFIRM
    BANK_PARTNER -->|"originates loans<br/>for compliance"| KLARNA
    WAREHOUSE -->|"credit facility"| KLARNA
    WAREHOUSE -->|"credit facility"| AFFIRM
    KLARNA -->|"securitizes loans"| ABS
    AFFIRM -->|"securitizes loans"| ABS

    KLARNA -->|"issues virtual cards"| CARD_NETWORK
    AFFIRM -->|"issues virtual cards"| CARD_NETWORK

