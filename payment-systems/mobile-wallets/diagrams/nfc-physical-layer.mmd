%%{init: {'theme': 'base', 'themeVariables': {'primaryColor': '#e3f2fd', 'primaryBorderColor': '#1565c0', 'lineColor': '#37474f'}}}%%

flowchart TD
    subgraph NFC_HANDSHAKE["NFC Payment Handshake -- Under 500ms"]
        A["POS Terminal activates<br/>RF field at 13.56 MHz<br/>ISO 14443 Type A or B"]
        B["Phone NFC controller detects<br/>RF field within 0 to 4 cm range<br/>Card Emulation mode activated"]
        C["SELECT PPSE<br/>Terminal sends command for<br/>2PAY.SYS.DDF01<br/>Phone responds with available AIDs"]
        D["SELECT AID<br/>Terminal picks payment app<br/>Visa: A0000000031010<br/>MC: A0000000041010"]
        E["GET PROCESSING OPTIONS<br/>Terminal sends PDOL data:<br/>amount, currency, country<br/>Phone returns AIP and AFL"]
        F["READ RECORD<br/>Terminal reads application data:<br/>DPAN, expiry, track 2 equivalent<br/>Only 2 to 4 APDU exchanges"]
        G["GENERATE AC<br/>Secure Element computes ARQC<br/>using token key, ATC,<br/>amount, and terminal data"]
        H["NFC Transmission Complete<br/>DPAN plus cryptogram sent<br/>Phone can be removed<br/>Total NFC time: 300 to 500ms"]
    end

    subgraph MODES["NFC Operating Modes"]
        M1["Card Emulation<br/>Phone acts as card<br/>Used for payments"]
        M2["Reader / Writer<br/>Phone reads NFC tags<br/>Used for Tap to Pay<br/>phone as terminal"]
        M3["Peer-to-Peer<br/>Two NFC devices exchange data<br/>Deprecated -- Android Beam"]
    end

    A --> B --> C --> D --> E --> F --> G --> H

    style A fill:#e3f2fd,stroke:#1565c0,stroke-width:2px
    style C fill:#fff3e0,stroke:#e65100,stroke-width:2px
    style G fill:#f3e5f5,stroke:#6a1b9a,stroke-width:2px
    style H fill:#e8f5e9,stroke:#2e7d32,stroke-width:2px
    style M1 fill:#e8f5e9,stroke:#2e7d32,stroke-width:2px
    style M2 fill:#fff3e0,stroke:#e65100,stroke-width:2px
    style M3 fill:#ffebee,stroke:#c62828,stroke-width:2px
    style NFC_HANDSHAKE fill:#fafafa,stroke:#9e9e9e
    style MODES fill:#fafafa,stroke:#9e9e9e
