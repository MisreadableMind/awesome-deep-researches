        end

        subgraph RTGS_BOX["RTGS - Real-Time Gross Settlement"]
            DCA_RTGS["Dedicated Cash Account<br/>Settles large-value payments<br/>Individual, real-time, gross<br/>In central bank money"]
        end

        subgraph TIPS_BOX["TIPS - Instant Payment Settlement"]
            DCA_TIPS["Dedicated Cash Account<br/>Settles instant payments<br/>24/7/365 availability<br/>Under 10 seconds"]
        end

        subgraph T2S_BOX["T2S - Securities Settlement"]
            DCA_T2S["Dedicated Cash Account<br/>Settles cash leg of<br/>securities transactions<br/>Delivery vs Payment"]
        end

        MCA ==>|"Allocate<br/>liquidity"| DCA_RTGS
        MCA ==>|"Allocate<br/>liquidity"| DCA_TIPS
        MCA ==>|"Allocate<br/>liquidity"| DCA_T2S
    end

    ESMIG ==> T2_PLATFORM

    subgraph FORMAT["Messaging"]
        ISO["All services use<br/>ISO 20022 format"]
    end

    T2_PLATFORM --- FORMAT

