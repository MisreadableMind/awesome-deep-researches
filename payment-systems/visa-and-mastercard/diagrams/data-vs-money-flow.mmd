%%{init: {'theme': 'base', 'themeVariables': {'primaryColor': '#e3f2fd', 'primaryBorderColor': '#1565c0'}}}%%

flowchart TD
    subgraph DATA["DATA FLOW - Authorization - Real-Time in 1-3 Seconds"]
        direction LR
        D_POS["POS Terminal"]
        D_ACQ["Acquirer<br/>Processor"]
        D_NET["Card Network<br/>Switch"]
        D_ISS["Issuer<br/>Processor"]
        D_BANK["Issuing<br/>Bank"]

        D_POS -->|"Auth request"| D_ACQ
        D_ACQ -->|"Route by BIN"| D_NET
        D_NET -->|"Forward + fraud score"| D_ISS
        D_ISS -->|"Decision request"| D_BANK

        D_BANK -.->|"Approve or Decline"| D_ISS
        D_ISS -.->|"Response"| D_NET
        D_NET -.->|"Response"| D_ACQ
        D_ACQ -.->|"Result"| D_POS
    end

    subgraph MONEY["MONEY FLOW - Settlement - Batch T+1 or T+2"]
        direction LR
        M_CH["Cardholder<br/>Bank Account"]
        M_ISS["Issuing<br/>Bank"]
        M_NET["Network<br/>Netting Engine"]
        M_ACQ["Acquiring<br/>Bank"]
        M_MERCH["Merchant<br/>Bank Account"]

        M_CH ==>|"Funds debited<br/>or posted to statement"| M_ISS
        M_ISS ==>|"Net settlement<br/>position"| M_NET
        M_NET ==>|"Net amount<br/>after netting"| M_ACQ
        M_ACQ ==>|"Deposit minus<br/>MDR fees"| M_MERCH
    end

    SEP["These two flows are SEPARATE.<br/>Data flows in real-time during purchase.<br/>Money flows later in batch settlement."]

    DATA --- SEP
    SEP --- MONEY

    style DATA fill:#e3f2fd,stroke:#1565c0,stroke-width:2px
    style MONEY fill:#e8f5e9,stroke:#2e7d32,stroke-width:2px
    style SEP fill:#fff3e0,stroke:#e65100,stroke-width:2px
    style D_NET fill:#1a237e,stroke:#1a237e,color:#fff
    style M_NET fill:#1a237e,stroke:#1a237e,color:#fff
