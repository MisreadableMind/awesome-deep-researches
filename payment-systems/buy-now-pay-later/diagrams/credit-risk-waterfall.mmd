        A_LOSS["Affirm<br/>Net charge-off rate: ~4.5%<br/>Includes longer-term loans"]
        AP_LOSS["Afterpay<br/>Net loss rate: ~1.8%<br/>Short-term Pay in 4 focus"]
    end

