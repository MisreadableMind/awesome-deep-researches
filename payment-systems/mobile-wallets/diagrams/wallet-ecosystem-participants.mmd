%%{init: {'theme': 'base', 'themeVariables': {'primaryColor': '#e3f2fd', 'primaryBorderColor': '#1565c0', 'lineColor': '#37474f'}}}%%

graph TD
    subgraph CONSUMER["Consumer Side"]
        CH["Cardholder<br/>Owns card and device"]
        DEVICE["Mobile Device<br/>iPhone, Android, Galaxy"]
    end

    subgraph WALLET_LAYER["Wallet Layer"]
        APPLE["Apple Pay<br/>Secure Enclave + eSE"]
        GOOGLE["Google Pay<br/>HCE + Cloud LUKs"]
        SAMSUNG["Samsung Pay<br/>eSE + Knox"]
    end

    subgraph TOKEN_LAYER["Token Infrastructure"]
        VTS["Visa Token Service<br/>VTS"]
        MDES["Mastercard MDES"]
        EMVCO["EMVCo<br/>Standards body<br/>Token and contactless specs"]
    end

    subgraph NETWORK_LAYER["Payment Network"]
        VISA["Visa<br/>VisaNet"]
        MC["Mastercard<br/>Banknet"]
    end

    subgraph MERCHANT_SIDE["Merchant Side"]
        TERMINAL["POS Terminal<br/>NFC Reader<br/>Verifone, Ingenico, PAX"]
        MERCHANT["Merchant<br/>Accepts payments"]
        ACQUIRER["Acquirer<br/>Processes merchant<br/>transactions"]
    end

    subgraph BANK_SIDE["Issuer Side"]
        ISSUER["Issuing Bank<br/>Chase, Citi, HDFC, Barclays"]
    end

    CH --> DEVICE
    DEVICE --> APPLE
    DEVICE --> GOOGLE
    DEVICE --> SAMSUNG

    APPLE --> VTS
    APPLE --> MDES
    GOOGLE --> VTS
    GOOGLE --> MDES
    SAMSUNG --> VTS
    SAMSUNG --> MDES

    EMVCO -.->|"defines specs"| VTS
    EMVCO -.->|"defines specs"| MDES

    VTS --> VISA
    MDES --> MC

    CH -->|"taps phone"| TERMINAL
    TERMINAL --> MERCHANT
    MERCHANT --> ACQUIRER
    ACQUIRER --> VISA
    ACQUIRER --> MC

    VISA --> ISSUER
    MC --> ISSUER

    style CH fill:#e8f5e9,stroke:#2e7d32,stroke-width:2px
    style APPLE fill:#e3f2fd,stroke:#1565c0,stroke-width:2px
    style GOOGLE fill:#e3f2fd,stroke:#1565c0,stroke-width:2px
    style SAMSUNG fill:#e3f2fd,stroke:#1565c0,stroke-width:2px
    style VTS fill:#f3e5f5,stroke:#6a1b9a,stroke-width:2px
    style MDES fill:#f3e5f5,stroke:#6a1b9a,stroke-width:2px
    style VISA fill:#1a237e,stroke:#1a237e,color:#fff
    style MC fill:#1a237e,stroke:#1a237e,color:#fff
    style ISSUER fill:#e3f2fd,stroke:#1565c0,stroke-width:2px
    style MERCHANT fill:#fff3e0,stroke:#e65100,stroke-width:2px
    style TERMINAL fill:#fff3e0,stroke:#e65100,stroke-width:2px
