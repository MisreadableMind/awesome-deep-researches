    subgraph BNPL_SIDE["Buy Now Pay Later"]
        B1["Credit Check<br/>Soft pull only (Pay in 4)<br/>No impact on credit score"]
        B2["Interest Rate<br/>0% APR for Pay in 4<br/>0-36% for installment loans"]
        B3["Repayment<br/>Fixed schedule (4 or 6-12 payments)<br/>Auto-debit from card/bank"]
        B4["Credit Limit<br/>Per-order approval<br/>$35 to $1,500 typical"]
        B5["Late Fees<br/>$0-8 per missed payment<br/>Some providers charge $0"]
