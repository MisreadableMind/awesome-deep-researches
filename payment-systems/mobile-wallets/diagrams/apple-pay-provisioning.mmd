%%{init: {'theme': 'base', 'themeVariables': {'primaryColor': '#e3f2fd', 'primaryBorderColor': '#1565c0', 'lineColor': '#37474f'}}}%%

flowchart TD
    subgraph PROVISION["Apple Pay Provisioning -- ID and V Flow"]
        P1["User opens Wallet app<br/>Scans card with camera<br/>or enters PAN manually"]
        P2["Apple encrypts card data<br/>Adds device ID, device certificate,<br/>Apple Account info"]
        P3["Apple servers identify network<br/>from BIN and route to TSP"]
        P4["TSP -- Visa VTS or MC MDES<br/>Receives encrypted card data<br/>Contacts issuing bank"]
        P5{"Issuer ID and V<br/>Decision"}
        P6["Green Path<br/>Approved -- no additional<br/>verification needed<br/>Low risk provisioning"]
        P7["Yellow Path<br/>Additional verification required<br/>SMS code, bank app push,<br/>phone call, or in-branch"]
        P8["Red Path<br/>Declined<br/>Card cannot be tokenized"]
        P9["User completes<br/>additional verification"]
        P10["TSP generates DPAN<br/>Device Account Number<br/>Mapped to real PAN<br/>in Token Vault"]
        P11["DPAN plus token keys<br/>provisioned into device<br/>embedded Secure Element<br/>via secure channel"]
        P12["Card appears in Wallet<br/>Virtual card image displayed<br/>Ready for transactions<br/>Real PAN never stored on device"]
    end

    P1 --> P2 --> P3 --> P4 --> P5
    P5 -->|"low risk"| P6
    P5 -->|"medium risk"| P7
    P5 -->|"high risk"| P8
    P6 --> P10
    P7 --> P9 --> P10
    P10 --> P11 --> P12

    style P4 fill:#f3e5f5,stroke:#6a1b9a,stroke-width:2px
    style P5 fill:#fff3e0,stroke:#e65100,stroke-width:2px
    style P6 fill:#e8f5e9,stroke:#2e7d32,stroke-width:2px
    style P7 fill:#fff3e0,stroke:#e65100,stroke-width:2px
    style P8 fill:#ffebee,stroke:#c62828,stroke-width:2px
    style P11 fill:#e3f2fd,stroke:#1565c0,stroke-width:2px
    style P12 fill:#e8f5e9,stroke:#2e7d32,stroke-width:2px
    style PROVISION fill:#fafafa,stroke:#9e9e9e
